# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
# Frontend → API (set on Vercel web project)
# NEXT_PUBLIC_API_URL=https://your-api.vercel.app/api/v1
# Comma-separated browser origins allowed to call the API (required for Vercel)
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://acs:acs_secret@localhost:5432/ai_content_studio?schema=public

# ─── Redis / BullMQ ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (API keys at rest) ───────────────────────────────
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-aes256gcm

# ─── Cloudflare R2 ───────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ai-content-studio
R2_PUBLIC_URL=

# ─── AI Providers (workspace keys override these defaults) ─────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ─── Publishing OAuth (per-platform, configured per workspace) ───
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/v1/oauth/youtube/callback

# ─── Cost saver (testing with minimal OpenAI spend) ──────────────
# true = OpenAI-only pipeline, shorter videos, fewer tokens per call
COST_SAVER_MODE=true
# true = skip DALL-E thumbnail (~$0.02–0.04 saved per video)
COST_SAVER_SKIP_THUMBNAIL=true
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
DEFAULT_DURATION_SECONDS=120
MAX_DURATION_SECONDS=180
COST_SAVER_MAX_VOICE_CHARS=2500
# Skip manual approve — pipeline goes straight to render when workers finish
COST_SAVER_AUTO_APPROVE=true
LOCAL_MEDIA_DIR=./data/media
LOCAL_MEDIA_PORT=3001
